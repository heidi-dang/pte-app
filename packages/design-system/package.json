{
  "name": "@pte-app/design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "default": "./dist/tokens/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test:unit": "tsx --test src/**/*.unit.test.ts"
  },
  "dependencies": {
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@pte-app/typescript-config": "*",
    "@pte-app/eslint-config": "*",
    "@types/react": "^19.1.0",
    "typescript": "^5.8.0",
    "tsx": "^4.19.0"
  }
}
