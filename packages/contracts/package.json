    "./environment": { "types": "./dist/environment.d.ts", "default": "./dist/environment.js" },
    "./error": { "types": "./dist/error.d.ts", "default": "./dist/error.js" },
    "./api": { "types": "./dist/api.d.ts", "default": "./dist/api.js" },
    "./pagination": { "types": "./dist/pagination.d.ts", "default": "./dist/pagination.js" },
    "./identifier": { "types": "./dist/identifier.d.ts", "default": "./dist/identifier.js" },
    "./datetime": { "types": "./dist/datetime.d.ts", "default": "./dist/datetime.js" },
    "./logging": { "types": "./dist/logging.d.ts", "default": "./dist/logging.js" },
    "./correlation": { "types": "./dist/correlation.d.ts", "default": "./dist/correlation.js" },
    "./feature-flag": { "types": "./dist/feature-flag.d.ts", "default": "./dist/feature-flag.js" },
    "./provider": { "types": "./dist/provider.d.ts", "default": "./dist/provider.js" },
    "./content-version": { "types": "./dist/content-version.d.ts", "default": "./dist/content-version.js" },
