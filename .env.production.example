# Deployment environment name (production, staging)
DEPLOYMENT_ENV=production

# Exact Git commit SHA to deploy
RELEASE_COMMIT=

# Production hostnames
WEB_DOMAIN=pte.tnaprovider.com.au
API_DOMAIN=api.tnaprovider.com.au
SCORING_DOMAIN=scoring.tnaprovider.com.au

# Internal upstream addresses (Docker Compose service names and ports)
WEB_UPSTREAM=web:3000
API_UPSTREAM=api:4000
SCORING_UPSTREAM=scoring:5000

# Internal application ports
WEB_INTERNAL_PORT=3000
API_INTERNAL_PORT=4000
SCORING_INTERNAL_PORT=5000

# Caddy ports
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# ACME email for Let's Encrypt certificate
ACME_EMAIL=admin@tnaprovider.com.au

# Application environment
NODE_ENV=production
LOG_LEVEL=info
APP_VERSION=0.0.0

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=pte_prod
POSTGRES_USER=pte_prod
POSTGRES_PASSWORD=
POSTGRES_SSL=false
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_CONNECTION_TIMEOUT_MS=5000
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_RETRY_ATTEMPTS=10
POSTGRES_RETRY_DELAY_MS=1000

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Web application
WEB_HOST=0.0.0.0
WEB_PORT=3000
WEB_ORIGIN=https://pte.tnaprovider.com.au
NEXT_PUBLIC_API_URL=https://api.tnaprovider.com.au
NEXT_PUBLIC_SCORING_URL=https://scoring.tnaprovider.com.au

# Authentication
SESSION_DURATION_MINUTES=1440
BCRYPT_ROUNDS=10
SESSION_COOKIE_NAME=pte_session
MAX_SESSIONS_PER_USER=10

# Cloudflare DNS
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PROXIED=true
CLOUDFLARE_TTL=120
CLOUDFLARE_DRY_RUN=true

# VPS
VPS_IP=

# Deployment paths
DEPLOY_ROOT=/opt/pte-app
BACKUP_ROOT=/opt/pte-app/backups
