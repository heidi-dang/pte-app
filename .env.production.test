DEPLOYMENT_ENV=test
RELEASE_COMMIT=test-local

WEB_DOMAIN=pte.test.local
API_DOMAIN=api.pte.test.local
SCORING_DOMAIN=scoring.pte.test.local

WEB_UPSTREAM=web:3000
API_UPSTREAM=api:4000
SCORING_UPSTREAM=scoring:5000

WEB_INTERNAL_PORT=3000
API_INTERNAL_PORT=4000
SCORING_INTERNAL_PORT=5000

CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443

ACME_EMAIL=test@example.com

NODE_ENV=test
LOG_LEVEL=info
APP_VERSION=test

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=pte_test
POSTGRES_USER=pte_test
POSTGRES_PASSWORD=test_password_only
POSTGRES_SSL=false
POSTGRES_MAX_CONNECTIONS=10
POSTGRES_CONNECTION_TIMEOUT_MS=5000
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_RETRY_ATTEMPTS=3
POSTGRES_RETRY_DELAY_MS=500

REDIS_HOST=redis
REDIS_PORT=6379

WEB_HOST=0.0.0.0
WEB_PORT=3000
WEB_ORIGIN=http://pte.test.local:8080
NEXT_PUBLIC_API_URL=http://api.pte.test.local
NEXT_PUBLIC_SCORING_URL=http://scoring.pte.test.local

SESSION_DURATION_MINUTES=1440
BCRYPT_ROUNDS=4
SESSION_COOKIE_NAME=pte_session_test
MAX_SESSIONS_PER_USER=10

DNS_MODE=DIRECT

CLOUDFLARE_ZONE_ID=test-zone-id
CLOUDFLARE_API_TOKEN=test-token
CLOUDFLARE_PROXIED=true
CLOUDFLARE_TTL=120
CLOUDFLARE_DRY_RUN=true

TUNNEL_HOSTNAME=test-tunnel.example.com
VPS_IP=127.0.0.1
PUBLIC_VERIFICATION_MODE=deferred

DEPLOY_ROOT=/tmp/pte-test-deploy
BACKUP_ROOT=/tmp/pte-test-backups
