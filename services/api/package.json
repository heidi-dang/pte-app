{
  "name": "@pte-app/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "tsx src/main.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --test 'dist/**/*.unit.test.js'",
    "test:integration": "node --test 'dist/**/*.integration.test.js'",
    "test:api": "node --test 'dist/phase-h/phase-h.api.test.js'",
    "test:phase-i": "node --test 'dist/phase-i/phase-i.api.test.js'"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.0.0",
    "@pte-app/database": "*",
    "@pte-app/contracts": "*",
    "@pte-app/schemas": "*",
    "@pte-app/types": "*",
    "bcrypt": "^5.1.1",
    "fastify": "^5.3.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "tsx": "^4.19.0",
    "@pte-app/typescript-config": "*"
  }
}
