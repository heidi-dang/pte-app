{
  "name": "@pte-app/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "tsx src/main.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "tsx --test 'src/**/*.unit.test.ts'",
    "test:integration": "tsx --test 'src/**/*.integration.test.ts'",
    "test:api": "tsx --test 'src/phase-h/phase-h.api.test.ts'"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.0.0",
    "@pte-app/database": "*",
    "@pte-app/contracts": "*",
    "@pte-app/types": "*",
    "bcrypt": "^5.1.1",
    "fastify": "^5.3.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "tsx": "^4.19.0",
    "@pte-app/typescript-config": "*"
  }
}
