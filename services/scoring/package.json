{
  "name": "@pte-app/scoring",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "tsx src/main.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --test --test-force-exit --import tsx/esm 'src/**/*.unit.test.ts'",
    "test:integration": "node --test --test-force-exit --import tsx/esm 'src/**/*.integration.test.ts'"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "fastify": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "tsx": "^4.19.0",
    "@pte-app/typescript-config": "*"
  }
}
